<% content_for :title, "Sign in" %>

<div class="form__box form--centered p-5 text-center mt-5">
  <h2 class="form__heading heading heading--big mb-5">Sign in</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), data: { turbo: false }) do |f| %>
    <div class="field mb-4">
      <%= f.label :email, class: "form__label" %><br />
      <%= f.email_field(
        :email,
        autofocus: true,
        autocomplete: "email",
        class: "form-control form__field"
      )%>
    </div>

    <div class="field">
      <%= f.label :password, class: "form__label" %><br />
      <%= f.password_field(
        :password,
        autocomplete: "current-password",
        class: "form-control form__field"
      ) %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="field mt-2">
        <%= f.check_box :remember_me, class: "form-check-input form__check-input" %>
        <%= f.label :remember_me, class: "form-check-label form__check-label" %>
      </div>
    <% end %>

    <div class="actions">
      <%= f.submit "Sign in", class: "button button--black button--big button--block mt-5 mb-3" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
