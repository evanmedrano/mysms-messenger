<% content_for :title, "Sign up" %>

<div class="form__box form--centered p-5 text-center mt-5">
  <h2 class="form__heading heading heading--big mb-5">Sign up</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), data: { turbo: false }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field mb-4">
      <%= f.label :email, class: "form__label" %><br />
      <%= f.email_field(
        :email,
        autofocus: true,
        autocomplete: "email",
        class: "form-control form__field"
      )%>
    </div>

    <div class="field">
      <%= f.label :password, class: "form__label" %>
      <% if @minimum_password_length %>
        <em class="form__label">
          (<%= @minimum_password_length %> characters minimum)
        </em>
      <% end %><br />
      <%= f.password_field(
        :password,
        autocomplete: "new-password",
        class: "form-control form__field"
      ) %>
    </div>

    <div class="actions">
      <%= f.submit "Sign up", class: "button button--black button--big button--block mt-5 mb-3" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
