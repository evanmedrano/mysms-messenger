<% content_for :title, "Forgot Password" %>

<div class="form__box form--centered p-5 text-center mt-5">
  <h2 class="form__heading heading heading--big mb-5">Forgot your password?</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field mb-4">
      <%= f.label :email, class: "form__label" %><br />
      <%= f.email_field(
        :email,
        autofocus: true,
        autocomplete: "email",
        class: "form-control form__field"
      )%>
    </div>

    <div class="actions">
      <%= f.submit "Send me reset password instructions", class: "button button--black button--big button--block mt-5 mb-3" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
